# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/secret_manager?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Encryption
MASTER_KEY="your-32-byte-master-key-here!!!"

# Registration
# Set to "true" to allow anyone to register
# Set to "false" to require invite code
ALLOW_SELF_REGISTRATION=false

# Invite codes (comma-separated) - only used when ALLOW_SELF_REGISTRATION=false
INVITE_CODES=ADMIN2024
