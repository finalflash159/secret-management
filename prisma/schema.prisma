// Prisma Schema for Secret Manager Tool

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User - System user
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  memberships   ProjectMember[]
  createdProjects Project[] @relation("ProjectOwner")
  orgMemberships OrgMember[]
  auditLogs     AuditLog[]
  secretVersions SecretVersion[]
  alerts        Alert[]
  createdSecrets Secret[] @relation("SecretCreatedBy")
  updatedSecrets Secret[] @relation("SecretUpdatedBy")
  invitationUses InvitationUse[]
  createdDynamicSecrets DynamicSecret[] @relation("DynamicSecretCreatedBy")
  updatedDynamicSecrets DynamicSecret[] @relation("DynamicSecretUpdatedBy")
}

// Organization - Team organization
model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  avatar      String?  // URL to avatar image
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  projects    Project[]
  members     OrgMember[]
  alerts      Alert[]
  invitations OrgInvitation[]
  integrations Integration[]
}

// Project - Project containing secrets
model Project {
  id             String   @id @default(cuid())
  name           String
  slug           String
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownerId        String
  owner          User     @relation("ProjectOwner", fields: [ownerId], references: [id])
  environments   ProjectEnvironment[]
  folders        Folder[]
  secrets        Secret[]
  dynamicSecrets DynamicSecret[]
  roles          Role[]
  members        ProjectMember[]
  alerts         Alert[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([orgId, slug])
}

// ProjectEnvironment - Environment (dev, staging, production)
model ProjectEnvironment {
  id        String   @id @default(cuid())
  name      String   // Development, Staging, Production
  slug      String   // dev, staging, prod
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  secrets   Secret[]
  folders   Folder[]
  dynamicSecrets DynamicSecret[]
  createdAt DateTime @default(now())

  @@unique([projectId, slug])
}

// Folder - Folder containing secrets (can be nested)
model Folder {
  id           String   @id @default(cuid())
  name         String
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  envId        String
  environment  ProjectEnvironment @relation(fields: [envId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children     Folder[] @relation("FolderHierarchy")
  secrets      Secret[]
  dynamicSecrets DynamicSecret[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([projectId, envId, parentId, name])
}

// Secret - Actual secret (encrypted)
model Secret {
  id          String    @id @default(cuid())
  key         String    // Secret name (NOT encrypted for search)
  value       String    // Encrypted value AES-256-GCM
  folderId    String
  folder      Folder    @relation(fields: [folderId], references: [id], onDelete: Cascade)
  envId       String
  environment ProjectEnvironment @relation(fields: [envId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   String
  createdByUser User @relation("SecretCreatedBy", fields: [createdBy], references: [id])
  updatedBy   String?
  updatedByUser User? @relation("SecretUpdatedBy", fields: [updatedBy], references: [id])
  version     Int       @default(1)
  expiresAt   DateTime? // Expiration date for the secret
  metadata    Json?     // Tags, notes, etc.
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  versions    SecretVersion[]

  @@unique([projectId, envId, folderId, key])
}

// SecretVersion - Version history of secret
model SecretVersion {
  id        String   @id @default(cuid())
  secretId  String
  secret    Secret   @relation(fields: [secretId], references: [id], onDelete: Cascade)
  value     String   // Encrypted value
  version   Int
  createdBy String
  user      User     @relation(fields: [createdBy], references: [id])
  createdAt DateTime @default(now())
}

// DynamicSecret - Dynamically generated credentials
model DynamicSecret {
  id          String    @id @default(cuid())
  name        String    // Display name for the dynamic secret
  provider    String    // postgresql, mysql, mongodb, redis
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  envId       String
  environment ProjectEnvironment @relation(fields: [envId], references: [id], onDelete: Cascade)
  folderId    String?
  folder      Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  rotationPeriod Int    @default(86400) // Rotation period in seconds (default: 24h)
  lastRotatedAt DateTime?
  nextRotationAt DateTime?
  config      Json      // Provider-specific configuration (host, port, database, etc.)
  createdBy   String
  createdByUser User    @relation("DynamicSecretCreatedBy", fields: [createdBy], references: [id])
  updatedBy   String?
  updatedByUser User?   @relation("DynamicSecretUpdatedBy", fields: [updatedBy], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  credentials DynamicSecretCredential[]
  rotationJobs RotationJob[]
  rotationLogs RotationLog[]

  @@unique([projectId, envId, name])
}

// DynamicSecretCredential - Generated credentials (retrieved on demand)
model DynamicSecretCredential {
  id              String    @id @default(cuid())
  dynamicSecretId String
  dynamicSecret   DynamicSecret @relation(fields: [dynamicSecretId], references: [id], onDelete: Cascade)
  username        String    // Generated username
  password        String    // Generated password (encrypted)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())

  @@index([dynamicSecretId])
}

// RotationJob - Scheduled rotation jobs
model RotationJob {
  id              String   @id @default(cuid())
  name            String
  dynamicSecretId String
  dynamicSecret   DynamicSecret @relation(fields: [dynamicSecretId], references: [id], onDelete: Cascade)
  cronExpression  String   // Cron expression: "0 0 * * *" = daily
  isActive        Boolean  @default(true)
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  rotationLogs    RotationLog[]

  @@unique([dynamicSecretId])
}

// RotationLog - Rotation history
model RotationLog {
  id              String   @id @default(cuid())
  rotationJobId    String?
  rotationJob     RotationJob? @relation(fields: [rotationJobId], references: [id], onDelete: SetNull)
  dynamicSecretId String
  dynamicSecret   DynamicSecret @relation(fields: [dynamicSecretId], references: [id], onDelete: Cascade)
  status          String   // success, failed
  oldCredentialId String?
  newCredentialId String?
  errorMessage    String?
  rotatedBy       String   // system, manual
  createdAt       DateTime @default(now())

  @@index([dynamicSecretId, createdAt])
}

// AuditLog - Activity logs
model AuditLog {
  id         String   @id @default(cuid())
  projectId  String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String   // created, updated, deleted, viewed, exported
  targetType String   // secret, folder, project, member
  targetId   String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([projectId, createdAt])
}

// ProjectMember - Project member with role
model ProjectMember {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

// Role - Role with permissions
model Role {
  id          String   @id @default(cuid())
  name        String   // Admin, Editor, Viewer
  slug        String   // admin, editor, viewer
  permissions Json     // ["secret:read", "secret:write", "member:manage"]
  isDefault   Boolean  @default(false)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members     ProjectMember[]

  @@unique([projectId, slug])
}

// OrgMember - Organization member
model OrgMember {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  orgId          String
  org            Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role           RoleType      // owner, admin, member
  invitedBy      String?       // userId who invited
  invitationId   String?       // OrgInvitation ID if joined via invite code
  createdAt      DateTime      @default(now())

  @@unique([userId, orgId])
}

// Role types for organization and project
enum RoleType {
  owner
  admin
  member
}

// Invitation codes for organization membership
model OrgInvitation {
  id           String          @id @default(cuid())
  orgId        String
  org          Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  code         String          @unique // 8-char alphanumeric
  email        String?         @unique // Optional: restrict to specific email
  role         RoleType        // admin, member
  maxUses      Int?            // null = unlimited
  usedCount    Int             @default(0)
  expiresAt    DateTime?       // null = never expires
  createdBy    String          // userId of admin who created
  revokedAt    DateTime?
  isRevoked    Boolean         @default(false)
  createdAt    DateTime        @default(now())

  // Relations
  uses         InvitationUse[]

  @@index([orgId, createdAt])
  @@index([code])
}

// Track who used each invitation
model InvitationUse {
  id            String        @id @default(cuid())
  invitationId  String
  invitation    OrgInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  usedAt        DateTime      @default(now())

  @@unique([invitationId, userId])
}

// Alert - User notifications and alerts
model Alert {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId       String?
  org         Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Alert content
  type        AlertType // info, warning, error, success, secret_expiry, security
  title       String
  message     String
  link        String?   // Optional link to related entity

  // Status
  read        Boolean   @default(false)
  readAt      DateTime?

  // Metadata
  metadata    Json?     // Additional data like secret name, expiry date, etc.

  createdAt   DateTime  @default(now())

  @@index([userId, read, createdAt])
  @@index([orgId, createdAt])
}

// Integration - Connected external services
model Integration {
  id          String   @id @default(cuid())
  orgId       String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  type        String   // github, aws, gcp, azure, slack
  name        String   // Display name
  config      Json     // API keys, tokens, etc. (encrypted)
  isActive    Boolean  @default(true)
  lastSyncAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  syncs       IntegrationSync[]

  @@unique([orgId, type])
}

// IntegrationSync - Sync history
model IntegrationSync {
  id              String   @id @default(cuid())
  integrationId   String
  integration     Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  direction       String   // push, pull
  status          String   // success, failed, pending
  secretsCount    Int      @default(0)
  errorMessage    String?
  createdAt       DateTime @default(now())
}

enum AlertType {
  info        // General information
  warning     // Warnings
  error       // Errors
  success     // Success messages
  secret_expiry    // Secret expiring soon
  secret_expired   // Secret expired
  security    // Security alerts
  member_added      // New member added
  member_removed   // Member removed
  access_granted    // Access granted
  access_revoked    // Access revoked
}
