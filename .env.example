# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/secret_manager"

# NextAuth
NEXTAUTH_URL="http://localhost:3002"
NEXTAUTH_SECRET="replace-with-openssl-rand-hex-32"
AUTH_SECRET="replace-with-openssl-rand-hex-32"

# Encryption (AES-256-GCM) — must be exactly 32 bytes, generate with: openssl rand -hex 32
MASTER_KEY="replace-with-32-byte-master-key-here"

# ── Registration ──────────────────────────────────────────────────────────────
# SUPER_MASTER_ADMIN=true:  only the bootstrap admin can create orgs; others must use invite codes
# SUPER_MASTER_ADMIN=false: any authenticated user can create orgs
SUPER_MASTER_ADMIN=false

# ── Cron Jobs ─────────────────────────────────────────────────────────────────
# Secret for authenticating cron rotation endpoint
CRON_SECRET="replace-with-openssl-rand-hex-32"

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3002"

# ── Docker Bootstrap (prod only) ─────────────────────────────────────────────
# Set these in .env before running docker compose up
# Bootstrap admin will be created automatically on first startup
BOOTSTRAP_EMAIL="admin@gondor.dev"
BOOTSTRAP_PASSWORD="Admin123456!"
BOOTSTRAP_NAME="Admin"
